# Copiá este archivo a `.env` y completá las claves del proveedor que uses.

# Proveedor activo: "anthropic" | "deepseek" | "groq"  (default: groq)
LLM_PROVIDER=groq

# Groq — https://console.groq.com/  (gratuito)
GROQ_API_KEY=gsk_tu-key-groq-aca
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1   # opcional, este es el default

# DeepSeek — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-tu-key-deepseek-aca
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1   # opcional, este es el default

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-tu-key-aca
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Base de datos (default: SQLite local, swap a Postgres en producción)
# DATABASE_URL=sqlite:///./askdocs.db
# DATABASE_URL=postgresql://user:pass@localhost/askdocs

# Parámetros del retriever (opcionales — tienen defaults razonables)
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=4
MAX_HISTORY_TURNS=6
